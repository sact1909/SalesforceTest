{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/SalesforceTest.Api/bin/Debug/net10.0/SalesforceTest.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/SalesforceTest.Api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7257;http://localhost:5298"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "Web",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-web",
      "program": "${workspaceFolder}/src/SalesforceTest.Web/bin/Debug/net10.0/SalesforceTest.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/SalesforceTest.Web",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7286;http://localhost:5123"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["API", "Web"],
      "stopAll": true
    }
  ]
}
