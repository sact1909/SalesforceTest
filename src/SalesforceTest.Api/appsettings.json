{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://localhost:7286",
    "http://localhost:5123"
  ],
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=salesforcetest.db"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_32_CHARS_MIN_SECRET_KEY",
    "Issuer": "SalesforceTestApi",
    "Audience": "SalesforceTestWeb",
    "ExpirationMinutes": "60"
  },
  "Salesforce": {
    "ClientId": "YOUR_SALESFORCE_CLIENT_ID",
    "ClientSecret": "YOUR_SALESFORCE_CLIENT_SECRET",
    "RedirectUri": "https://localhost:7257/api/salesforce/callback",
    "AuthBaseUrl": "https://login.salesforce.com"
  }
}
